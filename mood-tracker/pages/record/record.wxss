.container {
  padding: 30rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d3436;
  margin-bottom: 40rpx;
  display: block;
}

.mood-section, .trigger-section, .note-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #636e72;
  margin-bottom: 20rpx;
  display: block;
}

.mood-selector {
  display: flex;
  justify-content: space-between;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.mood-item.active {
  background: #f0e6ff;
  transform: scale(1.1);
}

.mood-emoji {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.mood-text {
  font-size: 22rpx;
  color: #636e72;
}

.mood-item.active .mood-text {
  color: #6C5CE7;
  font-weight: 500;
}

.trigger-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.trigger-item {
  padding: 16rpx 32rpx;
  background: #f5f6fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #636e72;
  transition: all 0.3s;
}

.trigger-item.active {
  background: #6C5CE7;
  color: #fff;
}

.note-input {
  width: 100%;
  height: 200rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.save-btn {
  background: #6C5CE7;
  color: #fff;
  border-radius: 50rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.save-btn::after {
  border: none;
}
